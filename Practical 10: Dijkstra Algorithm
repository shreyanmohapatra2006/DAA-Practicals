#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int graph[n][n];

    for(int i=0;i<n;i++)
        for(int j=0;j<n;j++)
            cin >> graph[i][j];

    int dist[n], visited[n] = {0};

    for(int i=0;i<n;i++)
        dist[i] = 999;

    dist[0] = 0;

    for(int count=0; count<n-1; count++) {
        int min = 999, u;

        for(int i=0;i<n;i++) {
            if(!visited[i] && dist[i] <= min) {
                min = dist[i];
                u = i;
            }
        }

        visited[u] = 1;

        for(int v=0; v<n; v++) {
            if(!visited[v] && graph[u][v] && dist[u] + graph[u][v] < dist[v]) {
                dist[v] = dist[u] + graph[u][v];
            }
        }
    }

    for(int i=0;i<n;i++)
        cout << "Distance from source to " << i << " = " << dist[i] << endl;

    return 0;
}

#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int arr[n], max = 0;

    for(int i=0;i<n;i++) {
        cin >> arr[i];
        if(arr[i] > max) max = arr[i];
    }

    int count[max+1] = {0};

    for(int i=0;i<n;i++)
        count[arr[i]]++;

    for(int i=0;i<=max;i++) {
        while(count[i]--)
            cout << i << " ";
    }

    return 0;
}

#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int graph[n][n];

    for(int i=0;i<n;i++)
        for(int j=0;j<n;j++)
            cin >> graph[i][j];

    int selected[n] = {0};
    selected[0] = 1;

    int edges = 0;

    while(edges < n-1) {
        int min = 999, x=0, y=0;

        for(int i=0;i<n;i++) {
            if(selected[i]) {
                for(int j=0;j<n;j++) {
                    if(!selected[j] && graph[i][j]) {
                        if(graph[i][j] < min) {
                            min = graph[i][j];
                            x = i;
                            y = j;
                        }
                    }
                }
            }
        }

        cout << x << " - " << y << " : " << min << endl;
        selected[y] = 1;
        edges++;
    }

    return 0;
}

#include <iostream>
#include <queue>
using namespace std;

int main() {
    int n;
    cin >> n;

    int graph[n][n];

    for(int i=0;i<n;i++)
        for(int j=0;j<n;j++)
            cin >> graph[i][j];

    int visited[n] = {0};
    queue<int> q;

    q.push(0);
    visited[0] = 1;

    while(!q.empty()) {
        int node = q.front();
        q.pop();

        cout << node << " ";

        for(int i=0;i<n;i++) {
            if(graph[node][i] && !visited[i]) {
                q.push(i);
                visited[i] = 1;
            }
        }
    }

    return 0;
}
